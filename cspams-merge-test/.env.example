APP_NAME=CSPAMS
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Manila
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:5173
VITE_API_BASE_URL=http://127.0.0.1:8000
APP_PORT=8000
FRONTEND_PORT=5173
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# Optional: shared demo password for monitor + demo school heads from DemoDataSeeder.
# Leave empty to derive a deterministic password from APP_KEY.
CSPAMS_DEMO_PASSWORD=

# Re-apply seeded passwords on every seeder run for consistent login credentials.
# Set false in production if you manually manage seeded account passwords.
CSPAMS_SYNC_SEEDED_PASSWORDS=true
# Shared temp password for seeded Santiago school-head accounts when setup-link flow is disabled.
CSPAMS_SEED_TEMP_PASSWORD=
# Set false in local/dev if you want seeded school-heads to log in directly using the temp password.
CSPAMS_REQUIRE_SETUP_LINK_FOR_SEEDED_SCHOOL_HEADS=true
# Set false in local/dev to allow login even when must_reset_password is flagged.
CSPAMS_ENFORCE_REQUIRED_PASSWORD_RESET=true

# Browser origins allowed to call the API in local/dev.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
# Frontend origins treated as first-party by Sanctum (required for cookie auth).
SANCTUM_STATEFUL_DOMAINS=127.0.0.1:5173,localhost:5173,127.0.0.1:8000,localhost:8000
# Short-lived bearer token policy for non-SPA API clients (minutes).
SANCTUM_TOKEN_EXPIRATION=30
# Rotate/re-issue before token expiry (minutes).
SANCTUM_TOKEN_REFRESH_BEFORE_MINUTES=3
# Enforce monitor MFA (recommended for division-level accounts).
CSPAMS_MONITOR_MFA_ENABLED=true
# One-time MFA code validity window (minutes).
CSPAMS_MONITOR_MFA_TTL_MINUTES=10
# Max code verification attempts before challenge lockout.
CSPAMS_MONITOR_MFA_MAX_ATTEMPTS=5
# Optional fixed MFA code for local/dev only (leave blank in production).
CSPAMS_MONITOR_MFA_TEST_CODE=
# Backup recovery code count issued on generation/reset.
CSPAMS_MONITOR_MFA_BACKUP_CODES_COUNT=8
# Pending MFA reset requests expire after this many minutes (default: 24 hours).
CSPAMS_MONITOR_MFA_RESET_REQUEST_TTL_MINUTES=1440
# Admin-approved MFA reset token expiry in minutes.
CSPAMS_MONITOR_MFA_RESET_APPROVAL_TTL_MINUTES=60
# Optional fixed MFA reset approval token for local/dev only.
CSPAMS_MONITOR_MFA_RESET_TEST_APPROVAL_TOKEN=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite + database queue is suitable for local/dev, but prefer MySQL/PostgreSQL
# plus Redis for higher-concurrency production deployments.
DB_CONNECTION=sqlite
DB_BUSY_TIMEOUT=5000
DB_JOURNAL_MODE=wal
DB_SYNCHRONOUS=normal
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
# Minutes until a session expires (keep short in production/staging).
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Local/dev over HTTP can keep this false; production/staging should set true (HTTPS).
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

REVERB_APP_ID=123456
REVERB_APP_KEY=cspams-reverb-key
REVERB_APP_SECRET=cspams-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REALTIME_ENABLED=false

# Database cache keeps Cache::lock() atomic across backend + queue containers.
CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional transactional email provider (Resend).
# Use either RESEND_KEY (preferred) or RESEND_API_KEY (matches Resend docs).
RESEND_KEY=
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
